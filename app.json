          "photosPermission": "Müşterinin mekân fotoğrafını sunumda kullanmak için galeri erişimi gerekir."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b9075d4a-71b4-473a-b80a-7c51b99e4336"
      }
    }
  }
